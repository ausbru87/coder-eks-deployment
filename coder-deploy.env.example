# Coder Deploy Environment - copy to coder-deploy.env (gitignored)

# =============================================================================
# Environment (optional)
# =============================================================================
# export TF_VAR_env_name="myenv"        # Prefixes resources: myenv-coder-*
# export TF_VAR_region="us-west-2"      # AWS region (default: us-west-2)
export TF_INPUT=false                   # Disable Terraform input prompts

# =============================================================================
# Domain Configuration (required)
# =============================================================================
export TF_VAR_domain="dev.example.com"
export TF_VAR_wildcard_domain="*.dev.example.com"
export TF_VAR_route53_zone_name="example.com"

# =============================================================================
# GitHub OAuth (required for bootstrap)
# =============================================================================
export TF_VAR_github_oauth_client_id="your-client-id"
export TF_VAR_github_oauth_client_secret="your-client-secret"
export TF_VAR_github_allowed_orgs="your-github-org"

# =============================================================================
# State Backend (auto-populated by scripts/create-tfstate-backend.sh)
# =============================================================================
# export TF_VAR_tfstate_bucket=""       # Auto-added by script
# export TF_VAR_tfstate_lock_table=""   # Auto-added by script

# =============================================================================
# Day 2 Config (required after Coder is running)
# =============================================================================
# Get token: coder login https://dev.example.com && coder tokens create --lifetime 8760h
export CODER_TOKEN=""

# =============================================================================
# Optional
# =============================================================================
export TF_VAR_grafana_domain=""  # e.g., grafana.dev.example.com (empty = no external access)
export TF_VAR_license_key=""     # Enterprise license key
